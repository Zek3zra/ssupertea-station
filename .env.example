# REQUIRED
# Paste the newly generated OpenRouteService key into Vercel, not into app.js.
OPENROUTESERVICE_API_KEY=

# The supplied Ssupertea Station coordinates.
# These are also built into api/route.js as safe public fallbacks.
SSUPERTEA_SHOP_LAT=10.406125231986707
SSUPERTEA_SHOP_LNG=122.9977403682195
SSUPERTEA_SHOP_NAME=Ssupertea Station

# Maximum straight-line distance accepted before requesting a route.
SSUPERTEA_MAX_ROUTE_KM=50


# Required by the secure /api/create-order endpoint.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
